{
	"plugins": ["@trivago/prettier-plugin-sort-imports"],

	"bracketSpacing": true,
	"quoteProps": "consistent",
	"semi": false,
	"singleQuote": true,
	"tabWidth": 4,
	"trailingComma": "es5",
	"useTabs": true,

	"importOrder": [
		"^@/api/.*$",
		"^@/components/ui/.*$",
		"^@/components/(?!ui/).*$",
		"^@/contexts/.*$",
		"^@/hooks/.*$",
		"^@/lib/.*$",
		"^@/types/.*$",
		"^@/styles/.*$",
		"^[./]"
	],
	"importOrderSeparation": true,
	"importOrderSortSpecifiers": true
}
